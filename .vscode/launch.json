{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Identity API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-identity",
            "program": "${workspaceFolder}/ChatApp.Backend/Services/IdentityService/IdentityService.API/bin/Debug/net10.0/IdentityService.API.dll",
            "cwd": "${workspaceFolder}/ChatApp.Backend/Services/IdentityService/IdentityService.API",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "User API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-user",
            "program": "${workspaceFolder}/ChatApp.Backend/Services/UserService/UserService.API/bin/Debug/net10.0/UserService.API.dll",
            "cwd": "${workspaceFolder}/ChatApp.Backend/Services/UserService/UserService.API",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Chat API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-chat",
            "program": "${workspaceFolder}/ChatApp.Backend/Services/ChatService/ChatService.API/bin/Debug/net10.0/ChatService.API.dll",
            "cwd": "${workspaceFolder}/ChatApp.Backend/Services/ChatService/ChatService.API",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "API Gateway",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-gateway",
            "program": "${workspaceFolder}/ChatApp.Backend/ApiGateway/bin/Debug/net10.0/ApiGateway.dll",
            "cwd": "${workspaceFolder}/ChatApp.Backend/ApiGateway",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ],
    "compounds": [
        {
            "name": "🚀 RUN ALL SERVICES",
            "configurations": ["Identity API", "User API", "Chat API", "API Gateway"],
            "stopAll": true
        }
    ]
}